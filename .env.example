# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── Groq API (get a free key at console.groq.com) ───────────────────────────
GROQ_API_KEY=gsk_your_api_key_here

# ── Database (used by Docker Compose) ────────────────────────────────────────
POSTGRES_DB=bcp_db
POSTGRES_USER=bcp_user
POSTGRES_PASSWORD=bcp_pass

# ── Spring Boot (overrides application.yml) ──────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/bcp_db
SPRING_DATASOURCE_USERNAME=bcp_user
SPRING_DATASOURCE_PASSWORD=bcp_pass

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
